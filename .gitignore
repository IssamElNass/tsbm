# ── tsbm — Results ────────────────────────────────────────────────────────────
# Keep the directory skeleton tracked via .gitkeep; ignore generated content.
results/runs.db
results/parquet/*
!results/parquet/.gitkeep
results/*.db
results/*.json

# ── tsbm — Datasets ───────────────────────────────────────────────────────────
# Track the small sample dataset; ignore large generated / user-supplied files.
datasets/*.parquet
datasets/*.parq
datasets/large*.csv
datasets/generated*.csv
# Keep: datasets/small_iot.csv and datasets/dataset_manifest.toml

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml
docker/.env

# ── Secrets / local config overrides ─────────────────────────────────────────
*.local.toml
.env.*
secrets/
